# AI
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL=claude-sonnet-4-5
TENANT_SECRET_KEY=change-me-in-production
AGENTIC_WHATSAPP_DRY_RUN=true

# Messaging (Twilio only; set real values if using provider=twilio)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...
TWILIO_WEBHOOK_VALIDATE=true
TWILIO_WEBHOOK_AUTH_TOKEN=
TWILIO_WEBHOOK_MAX_BODY_BYTES=65536
TWILIO_WEBHOOK_BODY_TIMEOUT_MS=10000
TWILIO_WEBHOOK_DEDUPE_TTL_MS=86400000
PUBLIC_BASE_URL=

# Server
PORT=3001
NODE_ENV=production
API_TOKEN=
API_TOKEN_READ=
API_TOKEN_WRITE=
API_TOKEN_ADMIN=
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=120
REPLAY_RETENTION_DAYS=30
REPLAY_RETENTION_INTERVAL_MS=3600000

# Storage
DB_PATH=/app/services/doctor-agent/data/doctor-agent.db

# Safety (recommended true for first hospital pilot)
DRY_RUN=true
